---
import { FOOTER_LINKS } from "../lib/constants";
---

<footer class="border-t border-border bg-bg py-16 pb-8">
  <div class="container-section">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-5">
      <div class="lg:col-span-1">
        <a
          href="#hero"
          class="flex items-center gap-3 text-lg font-bold tracking-tight text-text whitespace-nowrap"
        >
          <img
            src="/logo.png"
            alt="VeerTrade"
            width="24"
            height="24"
            class="rounded-lg"
          />
          <span class="inline-flex whitespace-nowrap"><span>Veer</span><span class="text-brand">Trade</span></span>
        </a>
        <p class="mt-3 text-sm text-muted">
          AI-Powered Algorithmic Trading for Indian Markets.
        </p>
      </div>

      <div>
        <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-subtle">
          Product
        </p>
        <ul class="space-y-3">
          {FOOTER_LINKS.product.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-muted transition-colors hover:text-text"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-subtle">
          Company
        </p>
        <ul class="space-y-3">
          {FOOTER_LINKS.company.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-muted transition-colors hover:text-text"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-subtle">
          Legal
        </p>
        <ul class="space-y-3">
          {FOOTER_LINKS.legal.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-muted transition-colors hover:text-text"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-subtle">
          Social
        </p>
        <ul class="space-y-3">
          {FOOTER_LINKS.social.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-muted transition-colors hover:text-text"
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-16 border-t border-border pt-8 text-center">
      <p class="text-sm text-muted">
        &copy; 2026 VeerTrade. All rights reserved.
      </p>
      <p class="mt-1 text-xs text-subtle">Trade Like A Veer.</p>
    </div>
  </div>
</footer>
