---
import { NAV_LINKS } from "../lib/constants";
import Button from "./Button.astro";
---

<nav
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  id="navbar"
  aria-label="Main navigation"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <a
      href="#hero"
      class="flex items-center gap-3 text-lg font-bold tracking-tight text-text whitespace-nowrap"
      aria-label="VeerTrade home"
    >
      <img
        src="/logo.png"
        alt="VeerTrade"
        width="28"
        height="28"
        class="rounded-lg"
      />
      <span class="inline-flex whitespace-nowrap"><span>Veer</span><span class="text-brand">Trade</span></span>
    </a>

    <div class="hidden items-center gap-8 md:flex" role="list">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class="nav-link text-sm font-medium text-subtle transition-colors hover:text-text"
          role="listitem"
        >
          {link.label}
        </a>
      ))}
    </div>

    <Button
      href="/signup"
      variant="primary"
      size="sm"
      label="Start Building"
      class="hidden md:inline-flex"
    />

    <button
      class="inline-flex items-center p-2 text-subtle md:hidden"
      id="mobile-menu-toggle"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        id="hamburger-icon"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>
</nav>

<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden bg-bg/95 backdrop-blur-xl"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
>
  <div class="flex h-full flex-col items-center justify-center gap-8">
    {NAV_LINKS.map((link) => (
      <a
        href={link.href}
        class="text-2xl font-medium text-muted transition-colors hover:text-brand"
      >
        {link.label}
      </a>
    ))}
    <a
      href="/signup"
      class="mt-4 rounded-lg bg-brand px-8 py-3 text-lg font-medium text-white shadow-lg shadow-brand/20 transition-all hover:bg-brand-hover"
    >
      Start Building
    </a>
    <button
      class="mt-8 text-sm text-subtle"
      id="mobile-menu-close"
      aria-label="Close navigation menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>
</div>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const close = document.getElementById("mobile-menu-close");
  const navbar = document.getElementById("navbar");

  if (toggle && menu && close) {
    const openMenu = () => {
      toggle.setAttribute("aria-expanded", "true");
      menu.classList.remove("hidden");
      document.body.style.overflow = "hidden";
      const firstLink = menu.querySelector("a");
      if (firstLink) setTimeout(() => firstLink.focus(), 100);
    };
    const closeMenu = () => {
      toggle.setAttribute("aria-expanded", "false");
      menu.classList.add("hidden");
      document.body.style.overflow = "";
      toggle.focus();
    };

    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      expanded ? closeMenu() : openMenu();
    });
    close.addEventListener("click", closeMenu);
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    menu.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu();
      if (e.key === "Tab") {
        const focusable = menu.querySelectorAll(
          'a[href], button:not([disabled])'
        );
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          (last as HTMLElement).focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          (first as HTMLElement).focus();
        }
      }
    });
  }

  if (navbar) {
    const links = navbar.querySelectorAll(".nav-link");
    const sections = document.querySelectorAll("section[id]");
    const setActive = () => {
      let current = "";
      sections.forEach((s) => {
        const rect = s.getBoundingClientRect();
        if (rect.top <= 150) current = s.id;
      });
      links.forEach((l) => {
        const href = l.getAttribute("href")?.slice(1);
        l.classList.toggle("text-text", href === current);
        l.classList.toggle("text-subtle", href !== current);
      });
    };
    window.addEventListener("scroll", setActive, { passive: true });
    setActive();

    navbar.classList.add("bg-transparent");
    window.addEventListener("scroll", () => {
      if (window.scrollY > 64) {
        navbar.classList.remove("bg-transparent");
        navbar.classList.add(
          "bg-bg/80",
          "backdrop-blur-xl",
          "border-b",
          "border-border/50"
        );
      } else {
        navbar.classList.add("bg-transparent");
        navbar.classList.remove(
          "bg-bg/80",
          "backdrop-blur-xl",
          "border-b",
          "border-border/50"
        );
      }
    });
  }
</script>
