---
import HeroScene from "./HeroThreeScene";
---

<section
  id="hero"
  class="relative flex min-h-screen items-center justify-center overflow-hidden"
  aria-labelledby="hero-heading"
>
  <HeroScene client:visible />

  <div class="hero-glow" />
  <div class="hero-fade" />

  <div class="relative z-20 mx-auto max-w-4xl px-6 text-center">
    <p class="animate-fade-in-up mb-4 text-sm font-semibold uppercase tracking-widest text-brand" style="animation-delay: 0.05s">
      AI-Powered Algorithmic Trading
    </p>
    <h1
      id="hero-heading"
      class="animate-fade-in-up text-5xl font-bold tracking-tight text-text md:text-7xl lg:text-8xl"
      style="animation-delay: 0.1s"
    >
      Trade Like A Veer.
    </h1>
    <p
      class="animate-fade-in-up mt-4 text-xl font-medium text-muted md:text-2xl"
      style="animation-delay: 0.3s"
    >
      Build. Backtest. Execute.
    </p>
    <p
      class="animate-fade-in-up mx-auto mt-4 max-w-2xl text-base text-subtle md:text-lg"
      style="animation-delay: 0.5s"
    >
      The easiest way to automate your trading strategies for Indian markets.
      Connect Zerodha. No coding required.
    </p>
    <div
      class="animate-fade-in-up mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
      style="animation-delay: 0.7s"
    >
      <a
        href="/signup"
        class="inline-flex items-center gap-2 rounded-lg bg-brand px-8 py-3.5 text-base font-medium text-white shadow-lg shadow-brand/20 transition-all duration-200 hover:bg-brand-hover hover:shadow-brand-hover/20 focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2 focus:ring-offset-bg active:scale-95"
      >
        Start Building Strategies
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
        </svg>
      </a>
      <a
        href="/demo"
        class="inline-flex items-center gap-2 rounded-lg border border-border px-8 py-3.5 text-base font-medium text-muted transition-all duration-200 hover:border-border-hover hover:bg-surface/80 hover:text-text focus:outline-none focus:ring-2 focus:ring-border-hover focus:ring-offset-2 focus:ring-offset-bg active:scale-95"
      >
        Watch Demo
      </a>
    </div>
    <p class="animate-fade-in-up mt-6 text-xs text-subtle" style="animation-delay: 0.9s">
      No credit card required &middot; Free during beta &middot; Zerodha account needed for live trading
    </p>
  </div>

  <div class="absolute bottom-8 left-1/2 z-20 -translate-x-1/2 animate-bounce">
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-subtle"
      aria-hidden="true"
    >
      <path d="M6 9l6 6 6-6" />
    </svg>
  </div>
</section>
