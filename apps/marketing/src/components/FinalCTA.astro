---
import WaitlistForm from "./WaitlistForm";
---

<section class="border-t border-border py-24 md:py-32">
  <div class="container-section text-center">
    <div class="mx-auto max-w-2xl">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-brand">
        Get Started
      </p>
      <h2 class="text-3xl font-bold tracking-tight text-text md:text-4xl">
        Ready to trade like a Veer?
      </h2>
      <p class="mt-4 text-lg text-muted">
        Join 500+ algorithmic traders already building strategies on VeerTrade.
        No credit card required.
      </p>
      <div class="mt-8 mx-auto max-w-md">
        <WaitlistForm client:load />
      </div>
      <p class="mt-3 text-xs text-subtle">
        Free forever during beta. Zerodha account required for live trading.
      </p>
    </div>
  </div>
</section>
